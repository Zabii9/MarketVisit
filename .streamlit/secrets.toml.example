# Never commit the real secrets.toml file.

# Personal Google account: deploy google_apps_script/Code.gs, then set these.
apps_script_upload_url = "YOUR_APPS_SCRIPT_WEB_APP_EXEC_URL"
apps_script_upload_token = "YOUR_LONG_RANDOM_SECRET_TOKEN"

# Google Workspace alternative: use a folder inside a Shared Drive.
drive_folder_id = ""

# Generate a password hash with:
# python -c "import hashlib,getpass; print(hashlib.sha256(getpass.getpass('Password: ').encode()).hexdigest())"
[users.admin]
display_name = "Administrator"
password_hash = "SHA256_HASH_OF_ADMIN_PASSWORD"
role = "admin"

[users.khi_user]
display_name = "Olpers KHI User"
password_hash = "SHA256_HASH_OF_PARTNER_PASSWORD"
role = "partner"
partner_codes = ["D70002202", "D70002246"]

[gcp_service_account]
type = "service_account"
project_id = "YOUR_PROJECT_ID"
private_key_id = "YOUR_NEW_PRIVATE_KEY_ID"
private_key = """-----BEGIN PRIVATE KEY-----
YOUR_NEW_PRIVATE_KEY
-----END PRIVATE KEY-----
"""
client_email = "YOUR_SERVICE_ACCOUNT@YOUR_PROJECT_ID.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "YOUR_CLIENT_CERT_URL"
universe_domain = "googleapis.com"
